# Database
DATABASE_URL="postgresql://piwiki:piwiki@localhost:5432/piwiki?schema=public"

# Application
NEXT_PUBLIC_APP_NAME="PI Wiki"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Edit Lock (FR-215)
EDIT_LOCK_TIMEOUT_MINUTES=5
EDIT_LOCK_HEARTBEAT_SECONDS=60

# Uploads
UPLOAD_DIR="./uploads"
MAX_IMAGE_SIZE_MB=10
MAX_FILE_SIZE_MB=50

# AI
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-5.5"
OPENAI_EMBEDDING_MODEL="text-embedding-3-small"
OPENAI_EMBEDDING_DIMENSIONS=1536
MAX_CHAT_CONTEXT_CHARS=16000
AI_AUTO_INDEX_ON_SAVE=false

# Auth (Sprint 1: 익명 사용자, 후속 SSO 도입)
DEFAULT_USER_NAME="익명"

# Logging
LOG_LEVEL="info"

# Email (FR-904) - 사내 SMTP 미설정 시 자동 비활성 (no-op)
SMTP_HOST=""                  # 예: mail.company.local
SMTP_PORT=25                  # 587 (TLS), 465 (SSL), 25 (plain)
SMTP_SECURE="false"           # SSL 사용 여부
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="PI Wiki <piwiki@example.com>"
NOTIFY_EMAIL_DOMAIN=""        # 사용자명 -> email 추론 (예: company.local -> hong@company.local)

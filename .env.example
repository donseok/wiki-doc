# Database (DB 사용자/스키마명 piwiki 는 운영 데이터 호환성을 위해 보존)
DATABASE_URL="postgresql://piwiki:piwiki@localhost:5432/piwiki?schema=public"

# Application
NEXT_PUBLIC_APP_NAME="Atlas"
NEXT_PUBLIC_APP_NAME_KO="아틀라스"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# AI Export 메타데이터 (선택, 미설정 시 NEXT_PUBLIC_APP_NAME 또는 'Atlas')
WIKI_NAME=""
WIKI_BASE_URL=""

# Edit Lock (FR-215)
EDIT_LOCK_TIMEOUT_MINUTES=5
EDIT_LOCK_HEARTBEAT_SECONDS=60

# Uploads
UPLOAD_DIR="./uploads"
MAX_IMAGE_SIZE_MB=10
MAX_FILE_SIZE_MB=50

# AI
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-5.5"
OPENAI_EMBEDDING_MODEL="text-embedding-3-small"
OPENAI_EMBEDDING_DIMENSIONS=1536
MAX_CHAT_CONTEXT_CHARS=16000
AI_AUTO_INDEX_ON_SAVE=false

# Auth (Sprint 1: 익명 사용자, 후속 SSO 도입)
DEFAULT_USER_NAME="익명"

# Import (FR-808 마크다운 일괄 가져오기, Round 4)
IMPORT_ALLOWED_USERS=""        # 콤마 분리 사용자명. 빈 값이면 모두 허용 (미허용 시 403). SSO 도입 시 NFR-303 권한 체크로 교체
IMPORT_MAX_ZIP_MB=50           # zip 1개 최대 크기(MB). 초과 시 413
IMPORT_MAX_FILES=500           # 한 번 업로드 파일 수 상한. 초과 시 400
IMPORT_MAX_FILE_KB=1024        # 단일 .md 최대 크기(KB). 초과 시 해당 파일만 failed 기록(전체 거부 X)

# Logging
LOG_LEVEL="info"

# Email (FR-904) - 사내 SMTP 미설정 시 자동 비활성 (no-op)
SMTP_HOST=""                  # 예: mail.company.local
SMTP_PORT=25                  # 587 (TLS), 465 (SSL), 25 (plain)
SMTP_SECURE="false"           # SSL 사용 여부
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="Atlas <atlas-wiki@example.com>"
NOTIFY_EMAIL_DOMAIN=""        # 사용자명 -> email 추론 (예: company.local -> hong@company.local)
